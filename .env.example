# spec2gcp Project Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ┌─────────────────────────────────────────────────────────────┐
# │  These go in ~/.bashrc (personal, machine-specific):        │
# │    GITHUB_COPILOT_PAT                                       │
# │    GOOGLE_APPLICATION_CREDENTIALS                           │
# └─────────────────────────────────────────────────────────────┘
#
# ┌─────────────────────────────────────────────────────────────┐
# │  These go in .env (project-specific):                       │
# │    GOOGLE_CLOUD_PROJECT                                     │
# │    GOOGLE_DEVELOPER_KNOWLEDGE_API_KEY                       │
# └─────────────────────────────────────────────────────────────┘

# ── Google Cloud Platform ─────────────────────────────────────
# GCP Project ID — visible in GCP Console header (not the project name)
# Example: my-project-123456
GOOGLE_CLOUD_PROJECT=my-project-XXXXXX

# ── MCP Servers (optional) ────────────────────────────────────
# Google Developer Knowledge API key — for developer-knowledge MCP server
# Create at: GCP Console → APIs & Services → Credentials → Create API Key
GOOGLE_DEVELOPER_KNOWLEDGE_API_KEY=AIzaSy_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
